# =============================================================================
#  PDF Agent — Environment Variable Template
# =============================================================================
#  HOW TO USE
#  1. Copy this file:   cp .env_template .env
#  2. Fill in the values for your chosen LLM provider.
#  3. Never commit .env to source control (it is already in .gitignore).
# =============================================================================


# -----------------------------------------------------------------------------
# AGENT SETTINGS
# -----------------------------------------------------------------------------

# LLM provider to use.
# Choices: azure (default) | openai | anthropic | gemini | bedrock
PDF_AGENT_LLM_PROVIDER=azure

# Model name.  Meaning depends on the provider — see notes per section below.
PDF_AGENT_MODEL=gpt-4o

# Directory where generated PDFs are saved.  Relative to the working directory.
PDF_AGENT_OUTPUT_DIR=output


# =============================================================================
#  AZURE AI FOUNDRY / AZURE OPENAI    (PDF_AGENT_LLM_PROVIDER=azure)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview


# =============================================================================
#  OPENAI    (PDF_AGENT_LLM_PROVIDER=openai)
# =============================================================================
OPENAI_API_KEY=sk-<your-openai-api-key>


# =============================================================================
#  ANTHROPIC CLAUDE    (PDF_AGENT_LLM_PROVIDER=anthropic)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-<your-anthropic-api-key>


# =============================================================================
#  GOOGLE GEMINI    (PDF_AGENT_LLM_PROVIDER=gemini)
# =============================================================================
GOOGLE_API_KEY=AIza<your-google-api-key>


# =============================================================================
#  AWS BEDROCK    (PDF_AGENT_LLM_PROVIDER=bedrock)
# =============================================================================
# Alternatively, attach an IAM role to your compute — then no keys are needed.
# Suggested model IDs:
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#   amazon.nova-pro-v1:0
#   meta.llama3-70b-instruct-v1:0
AWS_ACCESS_KEY_ID=AKIA<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
AWS_REGION=us-east-1
